{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vulnops.local/schemas/sast-raw-finding.schema.json",
  "title": "VulnOps SAST Raw Finding",
  "type": "object",
  "required": ["id", "chunk_id", "title", "severity", "confidence", "source_ref", "sink_ref", "entrypoint_ref", "evidence_refs", "lenses"],
  "additionalProperties": true,
  "properties": {
    "id": {"type": "string"},
    "chunk_id": {"type": "string"},
    "title": {"type": "string"},
    "severity": {"type": "string", "enum": ["critical", "high", "medium", "low", "info"]},
    "confidence": {"type": "string", "enum": ["high", "medium", "low"]},
    "source_ref": {"type": "string"},
    "sink_ref": {"type": "string"},
    "entrypoint_ref": {"type": "string"},
    "evidence_refs": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "lenses": {"type": "array", "items": {"type": "string"}},
    "description": {"type": "string"},
    "impact": {"type": "string"},
    "remediation": {"type": "string"},
    "false_positive_notes": {"type": "string"}
  }
}
